# SHE_CAN_FOUNDATION_API_KEY: Required for She Can Foundation API integrations.
# The environment automatically injects this at runtime.
SHE_CAN_FOUNDATION_API_KEY="MY_SHE_CAN_FOUNDATION_API_KEY"

# APP_URL: The URL where this applet is hosted.
# The environment automatically injects this at runtime.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
